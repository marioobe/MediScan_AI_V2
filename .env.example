# ─────────────────────────────────────────────
# Laravel Environment Configuration
# ─────────────────────────────────────────────
APP_NAME=MediScanAI
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# Database (MySQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=medical_classifier
DB_USERNAME=root
DB_PASSWORD=

# AI Service (FastAPI)
AI_SERVICE_URL=http://localhost:8001

# Session & Queue
SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

# ─────────────────────────────────────────────
# FastAPI Environment Configuration
# ─────────────────────────────────────────────
# None required - uses defaults
# Model storage: ../storage/models/
# Dataset storage: ../storage/datasets/
